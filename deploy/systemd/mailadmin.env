APP_ADDR=127.0.0.1:18080
APP_TRUST_PROXY=false

SESSION_SECRET=replace-with-64-char-random-secret
WEBMAIL_TOKEN_ENC_KEY=replace-with-separate-64-char-random-secret
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=mail.myupona.com
ADMIN_COOKIE_NAME=mailadmin_session
PORTAL_COOKIE_NAME=mailportal_session
SESSION_TTL_SECONDS=86400

DB_SOCKET=/var/lib/mysql/mysql.sock
DB_NAME=mailserver

DB_RO_USER=mailro
DB_RO_PASS=replace-with-db-readonly-password

DB_ADMIN_USER=mailadmin
DB_ADMIN_PASS=replace-with-db-admin-password

DEFAULT_DOMAIN=myupona.com
MAIL_HOST=mail.myupona.com

DOVECOT_BIN=/opt/apps/dovecot/bin
POSTFIX_CFG=/opt/apps/postfix/etc/postfix
MYSQL_BIN=mysql
OPENSSL_BIN=openssl

ADMIN_TABLE=app_admin_users
AUDIT_TABLE=app_audit_logs
ADMIN_WORKSPACE_BINDING_TABLE=app_admin_workspace_bindings

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
